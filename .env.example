# ============================================
# Yui eBay Auto - 環境変数設定ファイル
# ============================================
# このファイルを .env.local にコピーして、
# 各APIキーを入力してください。
# cp .env.example .env.local
# ============================================

# --- eBay API ---
# https://developer.ebay.com で取得
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_OAUTH_TOKEN=your_oauth_token
# Sandbox（テスト）か Production（本番）か
EBAY_ENVIRONMENT=sandbox

# --- Amazon PA-API ---
# https://affiliate.amazon.co.jp で取得
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your_tag-22

# --- Supabase ---
# https://supabase.com でプロジェクト作成後に取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_USER_ID=your_line_user_id

# --- Cron Secret (Vercelの定期実行用) ---
CRON_SECRET=your_random_secret_string

# --- 利益計算（簡易）---
DEFAULT_USD_JPY_RATE=155
PROFIT_SAFE_FX_BUFFER=5
EBAY_FEE_PERCENT=13.25
PROFIT_SAFETY_BUFFER_JPY=500
MIN_PROFIT_RATE_PERCENT=10
